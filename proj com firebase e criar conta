import React, { useEffect, useState } from 'react';
import {
  View,
  Text,
  TextInput,
  Button,
  FlatList,
  StyleSheet,
  Alert,
} from 'react-native';
import firebase from 'firebase';
import 'firebase/firestore';

const firebaseConfig = {
  apiKey: "AIzaSyAYqYdEtArJNdHganZFluKG-d0-IWtKuX0",
  authDomain: "proj-engenharia.firebaseapp.com",
  projectId: "proj-engenharia",
  storageBucket: "proj-engenharia.firebasestorage.app",
  messagingSenderId: "211742662085",
  appId: "1:211742662085:web:680c93ebb9f324a4b37fac"
};

if (!firebase.apps.length) {
  firebase.initializeApp(firebaseConfig);
}

const db = firebase.firestore();

export default function App() {
  const [codigo, setCodigo] = useState('');
  const [nome, setNome] = useState('');
  const [pessoas, setPessoas] = useState([]);

  
  const [usuario, setUsuario] = useState('');
  const [senha, setSenha] = useState('');
  const [logado, setLogado] = useState(false);

 
  const [tela, setTela] = useState('login');
  const [emailCadastro, setEmailCadastro] = useState('');
  const [senhaCadastro, setSenhaCadastro] = useState('');
  const [confirmarSenha, setConfirmarSenha] = useState('');

  useEffect(() => {
    if (!logado) return;

    const unsubscribe = db
      .collection('pessoas')
      .orderBy('codigo')
      .onSnapshot((snapshot) => {
        const lista = snapshot.docs.map((doc) => ({
          id: doc.id,
          ...doc.data(),
        }));
        setPessoas(lista);
      });

    return () => unsubscribe();
  }, [logado]);

  
  const fazerLogin = async () => {
    if (!usuario.trim() || !senha) {
      Alert.alert('Atenção', 'Preencha e-mail e senha.');
      return;
    }
    try {
      await firebase.auth().signInWithEmailAndPassword(usuario.trim(), senha);
      setLogado(true);
      Alert.alert('Sucesso', 'Login realizado com sucesso!');
    } catch (error) {
      Alert.alert('Erro ao entrar', error.message);
    }
  };

  const fazerCadastro = async () => {
    if (!emailCadastro.trim() || !senhaCadastro || !confirmarSenha) {
      Alert.alert('Atenção', 'Preencha todos os campos.');
      return;
    }
    if (senhaCadastro !== confirmarSenha) {
      Alert.alert('Erro', 'As senhas não coincidem.');
      return;
    }
    if (senhaCadastro.length < 6) {
      Alert.alert('Erro', 'A senha deve ter pelo menos 6 caracteres.');
      return;
    }
    try {
      await firebase.auth().createUserWithEmailAndPassword(
        emailCadastro.trim(),
        senhaCadastro
      );

    
      await firebase.auth().signOut();

      setEmailCadastro('');
      setSenhaCadastro('');
      setConfirmarSenha('');
      setTela('login');

      Alert.alert('Sucesso', 'Conta criada! Faça login para continuar.');
    } catch (error) {
      Alert.alert('Erro ao cadastrar', error.message);
    }
  };

  const sair = async () => {
    try {
      await firebase.auth().signOut();
      setLogado(false);
      setPessoas([]);
      setUsuario('');
      setSenha('');
    } catch (error) {
      Alert.alert('Erro', error.message);
    }
  };

  const adicionarPessoa = async () => {
    if (!codigo.trim() || !nome.trim()) return;

    try {
      const snapshot = await db
        .collection('pessoas')
        .where('codigo', '==', codigo.trim())
        .get();

      if (!snapshot.empty) {
        Alert.alert('Erro', 'Código já existe. Use um código único.');
        return;
      }

      await db.collection('pessoas').add({
        codigo: codigo.trim(),
        nome: nome.trim(),
      });

      setCodigo('');
      setNome('');
      Alert.alert('Sucesso', 'Pessoa cadastrada.');
    } catch (error) {
      console.error(error);
      Alert.alert('Erro', 'Não foi possível cadastrar.');
    }
  };

  const consultarPessoa = async () => {
    if (!codigo.trim()) return;

    try {
      const snapshot = await db
        .collection('pessoas')
        .where('codigo', '==', codigo.trim())
        .get();

      if (snapshot.empty) {
        setNome('');
        Alert.alert('Aviso', 'Nenhuma pessoa encontrada com esse código.');
      } else {
        const dados = snapshot.docs[0].data();
        setNome(dados.nome);
      }
    } catch (error) {
      console.error(error);
    }
  };

  const atualizarPessoa = async () => {
    if (!codigo.trim() || !nome.trim()) return;

    try {
      const snapshot = await db
        .collection('pessoas')
        .where('codigo', '==', codigo.trim())
        .get();

      if (snapshot.empty) {
        Alert.alert('Aviso', 'Nenhuma pessoa encontrada com esse código.');
        return;
      }

      const docId = snapshot.docs[0].id;
      await db.collection('pessoas').doc(docId).update({ nome: nome.trim() });

      setCodigo('');
      setNome('');
      Alert.alert('Sucesso', 'Pessoa atualizada.');
    } catch (error) {
      console.error(error);
      Alert.alert('Erro', 'Não foi possível atualizar.');
    }
  };

  const excluirPessoa = async () => {
    if (!codigo.trim()) return;

    try {
      const snapshot = await db
        .collection('pessoas')
        .where('codigo', '==', codigo.trim())
        .get();

      if (snapshot.empty) {
        Alert.alert('Aviso', 'Nenhuma pessoa encontrada com esse código.');
        return;
      }

      Alert.alert('Confirmação', 'Deseja realmente excluir esta pessoa?', [
        { text: 'Cancelar', style: 'cancel' },
        {
          text: 'Excluir',
          style: 'destructive',
          onPress: async () => {
            const docId = snapshot.docs[0].id;
            await db.collection('pessoas').doc(docId).delete();
            setCodigo('');
            setNome('');
            Alert.alert('Sucesso', 'Pessoa excluída.');
          },
        },
      ]);
    } catch (error) {
      console.error(error);
      Alert.alert('Erro', 'Não foi possível excluir.');
    }
  };

  const renderPessoa = ({ item }) => (
    <View style={styles.item}>
      <Text>
        <Text style={styles.bold}>Código:</Text> {item.codigo}
      </Text>
      <Text>
        <Text style={styles.bold}>Nome:</Text> {item.nome}
      </Text>
    </View>
  );



  if (tela === 'cadastro') {
    return (
      <View style={styles.container}>
        <Text style={styles.title}>Criar Conta</Text>

        <TextInput
          style={styles.input}
          placeholder="E-mail"
          value={emailCadastro}
          onChangeText={setEmailCadastro}
          keyboardType="email-address"
          autoCapitalize="none"
        />

        <TextInput
          style={styles.input}
          placeholder="Senha (mínimo 6 caracteres)"
          secureTextEntry
          value={senhaCadastro}
          onChangeText={setSenhaCadastro}
        />

        <TextInput
          style={styles.input}
          placeholder="Confirmar senha"
          secureTextEntry
          value={confirmarSenha}
          onChangeText={setConfirmarSenha}
        />

        <View style={styles.buttonRow}>
          <Button title="Cadastrar" onPress={fazerCadastro} color="#4CAF50" />
          <Button
            title="Voltar"
            onPress={() => setTela('login')}
            color="#9E9E9E"
          />
        </View>
      </View>
    );
  }


  if (!logado) {
    return (
      <View style={styles.container}>
        <Text style={styles.title}>Login</Text>

        <TextInput
          style={styles.input}
          placeholder="E-mail"
          value={usuario}
          onChangeText={setUsuario}
          keyboardType="email-address"
          autoCapitalize="none"
        />

        <TextInput
          style={styles.input}
          placeholder="Senha"
          secureTextEntry
          value={senha}
          onChangeText={setSenha}
        />

        <View style={styles.buttonRow}>
          <Button title="Entrar" onPress={fazerLogin} color="#2196F3" />
          <Button
            title="Criar conta"
            onPress={() => setTela('cadastro')}
            color="#4CAF50"
          />
        </View>
      </View>
    );
  }

  return (
    <View style={styles.container}>
      <Text style={styles.title}>Cadastro de Pessoas</Text>

      <View style={{ marginBottom: 15 }}>
        <Button title="Sair" color="#FF5722" onPress={sair} />
      </View>

      <TextInput
        style={styles.input}
        placeholder="Código (único)"
        value={codigo}
        onChangeText={setCodigo}
      />

      <TextInput
        style={styles.input}
        placeholder="Nome"
        value={nome}
        onChangeText={setNome}
      />

      <View style={styles.buttonRow}>
        <Button title="Adicionar" onPress={adicionarPessoa} color="#4CAF50" />
        <Button title="Atualizar" onPress={atualizarPessoa} color="#2196F3" />
        <Button title="Excluir" onPress={excluirPessoa} color="#F44336" />
      </View>

      <View style={styles.consultButtonContainer}>
        <Button title="Consultar" onPress={consultarPessoa} color="#9C27B0" />
      </View>

      <FlatList
        data={pessoas}
        keyExtractor={(item) => item.id}
        renderItem={renderPessoa}
        style={styles.list}
      />
    </View>
  );
}

const styles = StyleSheet.create({
  container: {
    flex: 1,
    padding: 20,
    backgroundColor: '#f5f5f5',
    justifyContent: 'center',
  },
  title: {
    fontSize: 24,
    fontWeight: 'bold',
    textAlign: 'center',
    marginBottom: 20,
  },
  input: {
    borderWidth: 1,
    borderColor: '#ccc',
    padding: 10,
    marginBottom: 10,
    borderRadius: 5,
    backgroundColor: '#fff',
  },
  buttonRow: {
    flexDirection: 'row',
    justifyContent: 'space-between',
    marginBottom: 10,
  },
  consultButtonContainer: {
    marginBottom: 20,
  },
  list: {
    marginTop: 10,
  },
  item: {
    padding: 12,
    backgroundColor: '#fff',
    marginBottom: 8,
    borderRadius: 5,
  },
  bold: {
    fontWeight: 'bold',
  },
});
