import React, { useEffect, useState } from 'react';
import {
  View,
  Text,
  TextInput,
  Button,
  FlatList,
  StyleSheet,
  Alert,
  ScrollView,
} from 'react-native';
import firebase from 'firebase';

const firebaseConfig = {
  apiKey: "AIzaSyAYqYdEtArJNdHganZFluKG-d0-IWtKuX0",
  authDomain: "proj-engenharia.firebaseapp.com",
  projectId: "proj-engenharia",
  storageBucket: "proj-engenharia.firebasestorage.app",
  messagingSenderId: "211742662085",
  appId: "1:211742662085:web:680c93ebb9f324a4b37fac"
};

if (!firebase.apps.length) {
  firebase.initializeApp(firebaseConfig);
}

const db = firebase.firestore();

export default function App() {
  const [usuario, setUsuario] = useState('');
  const [senha, setSenha] = useState('');
  const [logado, setLogado] = useState(false);
  const [tela, setTela] = useState('login');

  const [emailCadastro, setEmailCadastro] = useState('');
  const [senhaCadastro, setSenhaCadastro] = useState('');
  const [confirmarSenha, setConfirmarSenha] = useState('');

  const [tipoProduto, setTipoProduto] = useState('');
  const [quantidade, setQuantidade] = useState('');
  const [observacao, setObservacao] = useState('');
  const [solicitacaoEditandoId, setSolicitacaoEditandoId] = useState(null);
  const [solicitacoes, setSolicitacoes] = useState([]);

  useEffect(() => {
    if (!logado) return;

    const unsubscribe = db
      .collection('solicitacoes_compra')
      .orderBy('data', 'desc')
      .onSnapshot((snapshot) => {
        const lista = snapshot.docs.map((doc) => ({
          id: doc.id,
          ...doc.data(),
        }));
        setSolicitacoes(lista);
      });

    return () => unsubscribe();
  }, [logado]);

  const fazerLogin = async () => {
    if (!usuario.trim() || !senha) {
      Alert.alert('Atenção', 'Preencha e-mail e senha.');
      return;
    }
    try {
      await firebase.auth().signInWithEmailAndPassword(usuario.trim(), senha);
      setLogado(true);
    } catch (error) {
      Alert.alert('Erro ao entrar', error.message);
    }
  };

  const fazerCadastro = async () => {
    if (!emailCadastro.trim() || !senhaCadastro || !confirmarSenha) {
      Alert.alert('Atenção', 'Preencha todos os campos.');
      return;
    }
    if (senhaCadastro !== confirmarSenha) {
      Alert.alert('Erro', 'As senhas não coincidem.');
      return;
    }
    if (senhaCadastro.length < 6) {
      Alert.alert('Erro', 'A senha deve ter pelo menos 6 caracteres.');
      return;
    }
    try {
      await firebase.auth().createUserWithEmailAndPassword(
        emailCadastro.trim(),
        senhaCadastro
      );
      await firebase.auth().signOut();
      setEmailCadastro('');
      setSenhaCadastro('');
      setConfirmarSenha('');
      setTela('login');
      Alert.alert('Sucesso', 'Conta criada! Faça login para continuar.');
    } catch (error) {
      Alert.alert('Erro ao cadastrar', error.message);
    }
  };

  const sair = async () => {
    try {
      await firebase.auth().signOut();
      setLogado(false);
      setSolicitacoes([]);
      setUsuario('');
      setSenha('');
      limparFormulario();
    } catch (error) {
      Alert.alert('Erro', error.message);
    }
  };

  const limparFormulario = () => {
    setTipoProduto('');
    setQuantidade('');
    setObservacao('');
    setSolicitacaoEditandoId(null);
  };

  const adicionarSolicitacao = async () => {
    if (!tipoProduto.trim() || !quantidade.trim()) {
      Alert.alert('Atenção', 'Preencha o produto e a quantidade.');
      return;
    }
    if (isNaN(quantidade) || Number(quantidade) <= 0) {
      Alert.alert('Erro', 'A quantidade deve ser um número maior que zero.');
      return;
    }
    try {
      const hoje = new Date().toISOString().slice(0, 10);
      const userEmail = firebase.auth().currentUser?.email || '';
      await db.collection('solicitacoes_compra').add({
        tipoProduto: tipoProduto.trim(),
        quantidade: Number(quantidade),
        observacao: observacao.trim(),
        status: 'Pendente',
        data: hoje,
        solicitanteEmail: userEmail,
      });
      limparFormulario();
      Alert.alert('Sucesso', 'Solicitação enviada.');
    } catch (error) {
      console.error(error);
      Alert.alert('Erro', 'Não foi possível enviar a solicitação.');
    }
  };

  const consultarSolicitacao = (item) => {
    setTipoProduto(item.tipoProduto);
    setQuantidade(String(item.quantidade));
    setObservacao(item.observacao || '');
    setSolicitacaoEditandoId(item.id);
  };

  const atualizarSolicitacao = async () => {
    if (!solicitacaoEditandoId) return;
    if (!tipoProduto.trim() || !quantidade.trim()) {
      Alert.alert('Atenção', 'Preencha o produto e a quantidade.');
      return;
    }
    if (isNaN(quantidade) || Number(quantidade) <= 0) {
      Alert.alert('Erro', 'A quantidade deve ser um número maior que zero.');
      return;
    }
    try {
      await db.collection('solicitacoes_compra').doc(solicitacaoEditandoId).update({
        tipoProduto: tipoProduto.trim(),
        quantidade: Number(quantidade),
        observacao: observacao.trim(),
      });
      limparFormulario();
      Alert.alert('Sucesso', 'Solicitação atualizada.');
    } catch (error) {
      console.error(error);
      Alert.alert('Erro', 'Não foi possível atualizar.');
    }
  };

  const excluirSolicitacao = async (id) => {
    Alert.alert('Confirmação', 'Deseja realmente excluir esta solicitação?', [
      { text: 'Cancelar', style: 'cancel' },
      {
        text: 'Excluir',
        style: 'destructive',
        onPress: async () => {
          try {
            await db.collection('solicitacoes_compra').doc(id).delete();
            if (solicitacaoEditandoId === id) limparFormulario();
            Alert.alert('Sucesso', 'Solicitação excluída.');
          } catch (error) {
            console.error(error);
            Alert.alert('Erro', 'Não foi possível excluir.');
          }
        },
      },
    ]);
  };

  const renderSolicitacao = ({ item }) => (
    <View style={styles.item}>
      <Text><Text style={styles.bold}>Produto:</Text> {item.tipoProduto}</Text>
      <Text><Text style={styles.bold}>Quantidade:</Text> {item.quantidade}</Text>
      <Text><Text style={styles.bold}>Status:</Text> {item.status}</Text>
      <Text><Text style={styles.bold}>Data:</Text> {item.data}</Text>
      {item.observacao ? (
        <Text><Text style={styles.bold}>Obs:</Text> {item.observacao}</Text>
      ) : null}
      <View style={styles.itemButtons}>
        <Button title="Editar" onPress={() => consultarSolicitacao(item)} color="#2196F3" />
        <Button title="Excluir" onPress={() => excluirSolicitacao(item.id)} color="#F44336" />
      </View>
    </View>
  );

  if (tela === 'cadastro') {
    return (
      <View style={styles.container}>
        <Text style={styles.title}>Criar Conta</Text>

        <TextInput
          style={styles.input}
          placeholder="E-mail"
          value={emailCadastro}
          onChangeText={setEmailCadastro}
          keyboardType="email-address"
          autoCapitalize="none"
        />
        <TextInput
          style={styles.input}
          placeholder="Senha (mínimo 6 caracteres)"
          secureTextEntry
          value={senhaCadastro}
          onChangeText={setSenhaCadastro}
        />
        <TextInput
          style={styles.input}
          placeholder="Confirmar senha"
          secureTextEntry
          value={confirmarSenha}
          onChangeText={setConfirmarSenha}
        />

        <View style={styles.buttonRow}>
          <Button title="Cadastrar" onPress={fazerCadastro} color="#4CAF50" />
          <Button title="Voltar" onPress={() => setTela('login')} color="#9E9E9E" />
        </View>
      </View>
    );
  }

  if (!logado) {
    return (
      <View style={styles.container}>
        <Text style={styles.title}>Login</Text>

        <TextInput
          style={styles.input}
          placeholder="E-mail"
          value={usuario}
          onChangeText={setUsuario}
          keyboardType="email-address"
          autoCapitalize="none"
        />
        <TextInput
          style={styles.input}
          placeholder="Senha"
          secureTextEntry
          value={senha}
          onChangeText={setSenha}
        />

        <View style={styles.buttonRow}>
          <Button title="Entrar" onPress={fazerLogin} color="#2196F3" />
          <Button title="Criar conta" onPress={() => setTela('cadastro')} color="#4CAF50" />
        </View>
      </View>
    );
  }

  return (
    <ScrollView contentContainerStyle={styles.container}>
      <Text style={styles.title}>Solicitação de Compra</Text>

      <View style={{ marginBottom: 15 }}>
        <Button title="Sair" color="#FF5722" onPress={sair} />
      </View>

      <TextInput
        style={styles.input}
        placeholder="Nome / Descrição do Produto"
        value={tipoProduto}
        onChangeText={setTipoProduto}
      />
      <TextInput
        style={styles.input}
        placeholder="Quantidade"
        value={quantidade}
        onChangeText={setQuantidade}
        keyboardType="numeric"
      />
      <TextInput
        style={[styles.input, styles.textarea]}
        placeholder="Observações / Justificativa (opcional)"
        value={observacao}
        onChangeText={setObservacao}
        multiline
        numberOfLines={4}
      />

      <View style={styles.buttonRow}>
        {solicitacaoEditandoId ? (
          <>
            <Button title="Atualizar" onPress={atualizarSolicitacao} color="#2196F3" />
            <Button title="Cancelar" onPress={limparFormulario} color="#9E9E9E" />
          </>
        ) : (
          <Button title="Enviar Solicitação" onPress={adicionarSolicitacao} color="#4CAF50" />
        )}
      </View>

      <Text style={styles.sectionTitle}>Minhas Solicitações</Text>

      <FlatList
        data={solicitacoes}
        keyExtractor={(item) => item.id}
        renderItem={renderSolicitacao}
        style={styles.list}
        scrollEnabled={false}
      />
    </ScrollView>
  );
}

const styles = StyleSheet.create({
  container: {
    flexGrow: 1,
    padding: 20,
    backgroundColor: '#f5f5f5',
    justifyContent: 'center',
  },
  title: {
    fontSize: 24,
    fontWeight: 'bold',
    textAlign: 'center',
    marginBottom: 20,
  },
  sectionTitle: {
    fontSize: 18,
    fontWeight: 'bold',
    marginTop: 20,
    marginBottom: 10,
  },
  input: {
    borderWidth: 1,
    borderColor: '#ccc',
    padding: 10,
    marginBottom: 10,
    borderRadius: 5,
    backgroundColor: '#fff',
  },
  textarea: {
    height: 80,
    textAlignVertical: 'top',
  },
  buttonRow: {
    flexDirection: 'row',
    justifyContent: 'space-between',
    marginBottom: 10,
    gap: 10,
  },
  list: {
    marginTop: 10,
  },
  item: {
    padding: 12,
    backgroundColor: '#fff',
    marginBottom: 8,
    borderRadius: 5,
  },
  itemButtons: {
    flexDirection: 'row',
    justifyContent: 'flex-end',
    gap: 10,
    marginTop: 8,
  },
  bold: {
    fontWeight: 'bold',
  },
});
